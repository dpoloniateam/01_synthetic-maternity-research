    {
      "question_id": "V3_POST_Q03",
      "version": 3,
      "journey_phase": "postpartum",
      "question_text": "Imagine it's six weeks after birth. You're sitting in the GP surgery for your postnatal check. The appointment lasts ten minutes. What do you hope will happen in that room — and what does happen?",
      "question_type": "scenario",
      "probes": [
        {
          "probe_id": "V3_POST_Q03_P01",
          "probe_text": "Were there things you wanted to raise — about your mental health, your relationship, your body, or your sense of yourself — that the appointment didn't create space for?",
          "probe_type": "elaboration",
          "target_latent_dimensions": [
            "power_dynamics",
            "identity_tensions"
          ],
          "source": "base"
        },
        {
          "probe_id": "V3_POST_Q03_P02",

    {
      "question_id": "V3_BIRTH_Q01",
      "version": 3,
      "journey_phase": "birth",
      "question_text": "Imagine you've written a birth plan and you arrive at the labour ward. The midwife who receives you glances at your plan briefly, sets it aside, and moves on to routine checks. How does that moment land for you?",
      "question_type": "scenario",
      "probes": [
        {
          "probe_id": "V3_BIRTH_Q01_P01",
          "probe_text": "What had you put into that birth plan — and what had you hoped it would communicate about you, beyond the practical preferences?",
          "probe_type": "elaboration",
          "target_latent_dimensions": [
            "autonomy_vs_dependence",
            "identity_tensions"
          ],
          "source": "base"
        },
        {
          "probe_id": "V3_BIRTH_Q01_P02",
          "probe_text": "In that moment, did you say anything — or did you let it go? What shaped your response?",
          "probe_type": "emotion",
          "target_latent_dimensions": [
            "power_dynamics",
            "dignity_respect"
          ],
          "source": "base"
        },
        {
          "probe_id": "V3_BIRTH_Q01_P03",
          "probe_text": "Looking back, how much of what you'd hoped for from your birth actually happened — and for the parts that didn't, how have you made sense of that?",
          "probe_type": "contrast",
          "target_latent_dimensions": [
            "autonomy_vs_dependence",
            "trust_distrust"
          ],
          "source": "base"
        },
        {
          "probe_text": "What has it been like having more frequent monitoring and specialist appointments?",
          "probe_type": "elaboration",
          "target_latent_dimensions": [
            "structural_barriers",
            "continuity_of_care"
          ],
          "probe_id": "V3_BIRTH_Q01_UNIV_04",
          "source": "universal_adaptation"
        },
        {
          "probe_text": "How has your medical risk status changed how you relate to your care team?",
          "probe_type": "motivation",
          "target_latent_dimensions": [
            "power_dynamics",
            "trust_distrust"
          ],
          "probe_id": "V3_BIRTH_Q01_UNIV_05",
          "source": "universal_adaptation"
        },
        {
          "probe_text": "What are your specific fears about childbirth, and have your care providers addressed them?",
          "probe_type": "emotion",
          "target_latent_dimensions": [
            "trust_distrust",
            "autonomy_vs_dependence"
          ],
          "probe_id": "V3_BIRTH_Q01_UNIV_06",
          "source": "universal_adaptation"
        }

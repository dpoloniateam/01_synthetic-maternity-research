            "power_dynamics",
            "dignity_respect"
          ],
          "source": "base"
        },
        {
          "probe_id": "V3_BIRTH_Q03_P02",
          "probe_text": "Was there a particular person — a midwife, doctor, your partner, or anyone else — who made you feel anchored in that situation? What did they do that helped?",
          "probe_type": "elaboration",
          "target_latent_dimensions": [
            "continuity_of_care",
            "partner_role"
          ],
          "source": "base"
        },
        {
          "probe_id": "V3_BIRTH_Q03_P03",

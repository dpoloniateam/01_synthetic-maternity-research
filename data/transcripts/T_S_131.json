    {
      "turn_number": 17,
      "role": "interviewer",
      "type": "question",
      "text": "When you think about the emotional landscape of your pregnancy — the highs, the anxieties, the uncertainties — what feelings were most prominent, and how well did your care environment support you in managing them?",
      "question_id": "V2_PREG_Q03",
      "probe_id": null,
      "target_dimensions": [

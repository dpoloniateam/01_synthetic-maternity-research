    {
      "turn_number": 19,
      "role": "interviewer",
      "type": "question",
      "text": "During your pregnancy, what did you expect in terms of having a consistent midwife or care provider who knew your history and situation? And what continuity of care did you actually experience?",
      "question_id": "V4_PREG_Q03",
      "probe_id": null,
      "target_dimensions": [
        "goals",
        "latent_needs"
      ],
      "target_latent": [
        "continuity_of_care",
        "trust_distrust"
      ],
      "input_tokens": 0,

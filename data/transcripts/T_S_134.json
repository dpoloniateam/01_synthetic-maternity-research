    {
      "turn_number": 27,
      "role": "interviewer",
      "type": "question",
      "text": "During pregnancy, what did you expect the role of your family, friends, or community to be in supporting you? And how did that informal support network actually show up — or not?",
      "question_id": "V4_PREG_Q07",
      "probe_id": null,
      "target_dimensions": [
        "motivations",
        "latent_needs"
      ],
      "target_latent": [
        "informal_care_networks",
        "intergenerational_patterns"
      ],
      "input_tokens": 0,
